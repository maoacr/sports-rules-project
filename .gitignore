# ============================================================================
# Sports Rules App — Git Ignore
# ============================================================================

# --- Flutter / Dart ---------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
# pubspec.lock is NOT ignored — this is an app project (not a library),
# so we want reproducible builds across all environments. Flutter
# convention: app projects commit pubspec.lock, libraries do not.

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# Coverage
coverage/
*.lcov

# Tests / generated
*.g.dart
*.freezed.dart
test/.test_coverage.dart

# Exception: Isar storage schema is committed so the production code
# compiles out of the box without requiring every developer to run
# build_runner locally. Regenerate with
# `dart run build_runner build --force-jit`
# when CachedSport/CachedLaw/CachedArticle/CachedDecision schemas change
# in lib/core/storage/isar_storage.dart.
!lib/core/storage/isar_storage.g.dart

# --- Secrets / Credentials (NEVER commit) -----------------------------------
# Real `.env` file with API keys and credentials
.env
.env.local
.env.*.local

# Firebase platform configs (contain API keys)
**/GoogleService-Info.plist
**/google-services.json
ios/Runner/GoogleService-Info.plist
android/app/google-services.json

# Apple Developer / signing
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Runner.xcworkspace/xcuserdata/
ios/Runner.xcodeproj/project.xcworkspace/xcuserdata/
ios/Runner.xcodeproj/xcuserdata/
**/*.mobileprovision
**/*.p12
**/*.cer
**/*.key
**/*.pem
**/keystore.properties
**/key.properties

# Gradle
android/.gradle/
android/local.properties
android/key.properties
android/app/upload-keystore.jks

# RevenueCat
revenuecat.json

# --- Local artifacts --------------------------------------------------------
*.log
*.tmp
.tmp/

# --- Firebase emulator (local state, safe to delete) ------------------------
.firebase/
firebase-debug.log
ui-debug.log
firestore-debug.log
firebase-export/

# --- SDD orchestration state -----------------------------------------------
.PlanningRoom/

# --- node_modules under scripts/ (covered by scripts/.gitignore too, but
#     adding here protects against deleting scripts/.gitignore accidentally)
scripts/node_modules/
