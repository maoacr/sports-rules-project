# ============================================================================
# Sports Rules App — Environment Variables
# ============================================================================
# DO NOT commit this file. It is excluded via .gitignore.
#
# Copy this file to `.env` and fill in your real values.
# On CI/CD or build servers, inject these as build-time --dart-define flags.
# ============================================================================

# ----------------------------------------------------------------------------
# Firebase — Web API key (used by Firebase JS SDK and for client init)
# ----------------------------------------------------------------------------
FIREBASE_WEB_API_KEY=

# ----------------------------------------------------------------------------
# Firebase — App IDs (per platform)
# ----------------------------------------------------------------------------
FIREBASE_ANDROID_APP_ID=
FIREBASE_IOS_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_AUTH_DOMAIN=

# ----------------------------------------------------------------------------
# Google Sign-In (reversed client ID for iOS URL scheme)
# Format: com.googleusercontent.apps.<REVERSED_CLIENT_ID>
# Get this from GoogleService-Info.plist (iOS) and google-services.json (Android)
# ----------------------------------------------------------------------------
GOOGLE_REVERSED_CLIENT_ID=com.googleusercontent.apps.YOUR_CLIENT_ID

# ----------------------------------------------------------------------------
# RevenueCat
# Public SDK API keys (safe to ship in client builds; scoped per platform).
# ----------------------------------------------------------------------------
REVENUECAT_API_KEY_ANDROID=
REVENUECAT_API_KEY_IOS=

# ----------------------------------------------------------------------------
# App Links / Universal Links
# The domain used for shared deep links.
# ----------------------------------------------------------------------------
APP_LINK_DOMAIN=sportsrules.app

# ----------------------------------------------------------------------------
# Apple Sign-In
# Service ID used for Sign in with Apple web flow (not required for native mobile).
# ----------------------------------------------------------------------------
APPLE_SERVICE_ID=
APPLE_TEAM_ID=

# ----------------------------------------------------------------------------
# Development toggles (compile-time, set via --dart-define)
# ----------------------------------------------------------------------------
# When `true`, the app uses the in-memory FakePurchasesRepository and
# never talks to RevenueCat. No App Store / Play Console accounts needed.
# Use for local dev, manual QA and CI. Default: false.
#   flutter run --dart-define=USE_FAKE_PURCHASES=true
USE_FAKE_PURCHASES=false
